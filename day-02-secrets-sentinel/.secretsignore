# .secretsignore — patterns SecretSentinel will skip
# Syntax: glob patterns, one per line. Lines starting with # are comments.

# Test and example files
*.example
*.sample
**/test_data/**
**/fixtures/**
**/testdata/**
**/__tests__/**
**/tests/**/*.json

# Documentation examples
docs/**
*.md

# Lock files (too many false positives)
package-lock.json
yarn.lock
poetry.lock
Pipfile.lock

# Build artifacts
dist/**
build/**
*.min.js

# IDE and tooling
.vscode/**
.idea/**

# This scanner's own sample data
sample_data/**
